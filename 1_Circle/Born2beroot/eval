printf "#Architecture: "
uname -a

printf "#CPU physical : "
grep "physical id" /proc/cpuinfo | sort -u | wc -l

printf "#vCPU : "
grep "processor" /proc/cpuinfo | sort -u | wc -l

printf "#Memory Usage: "
free -m | grep "Mem" | awk '{printf "%d/%dMB (%.2f%%)\n", $3, $2, $3/$2 * 100}'

printf "#Disk Usage: "
df -a -BM | grep "/dev/mapper" | awk '{used+=$3}END{print used}' | tr -d '\n'
printf "/"
df -a -BM | grep "/dev/mapper" | awk '{total+=$3+$4}END{printf ("%d", total/1024)}' | tr -d '\n'
printf "Gb ("
df -a -BM | grep "/dev/mapper" | awk '{used+=$3; total+=$3+$4}END{printf ("%d", used/total*100)}' | tr -d '\n'
printf "%%)\n"

printf "#CPU load: "
mpstat | grep "all" | awk '{printf "%.1f%%\n", 100-$13}'

printf "#Last boot: "
who -b | awk '{printf $3" "$4"\n"}'

printf "#LVM use: "
if [ "$(lsblk | grep lvm | wc -l)" -gt 0 ] ; then printf "yes\n" ; else printf "no\n" ; fi

printf "#Connections TCP : "
ss | grep -i tcp | wc -l | tr -d '\n'
printf " ESTABLISHED\n"

printf "#User log: "
who | wc -l

printf "#Network: "
hostname -I | tr -d '\n'
printf "("
ip link show | awk '$1 == "link/ether" {print $2}' | sed '2, $d' | tr -d '\n'
printf ")\n"

printf "#Sudo : "
journalctl _COMM=sudo | wc -l | tr -d '\n'
printf " cmd\n"

exit 0
