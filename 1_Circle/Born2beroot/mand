/etc/ssh/sshd_config
o	- hostname은 gitkim42로 설정
o	- 비밀번호는 정책을 따라야 한다 (대문자 + 소문자 + 숫자 + 10자 이상)
o	- sudo를 설치해야한다
o	- user42 그룹 및 sudo 그룹에 속해야한다.
o	- 디펜스 중 유저를 만들고 그룹에 추가하는 작업을 할 수 있어야 한다.
o	- 비밀번호 정책을 만들어라
		o-- 30일마다 폐기 PASS_MAX_DAYS
		o-- 비밀번호 수정 최소 허용 일자는 2일 PASS_MIN_DAYS
		o-- 암호 폐기 7일 전에 경고 메세지 PASS_WARN_AGE
		o-- 최소 10글자 PASS_MIN_LEN >> /etc/login.defs
		apt -y install libpam-pwquality
		vim /etc/pam.d/common-password
		vim /etc/security/pwquality...
		https://community.learnlinux.tv/t/etc-pam-d-common-password-example/2785
		https://www.server-world.info/en/note?os=Debian_12&p=pam&f=1#google_vignette
		o-- 대문자, 소문자, 숫자가 포함되어야하며 동일 문자가 연속 3개 안됨
			u(l,d)credit=-1/ minclass = 3/ maxrepeat = 3
		o-- 유저의 이름이 포함되면 안된다
			reject_username = 1
		o-- 이전 암호에 7자 이상 속하는걸 재사용하면 안된다.
			difok = 7
		o-- 루트 비밀번호도 마찬가지
			enforce_for_root
	- sudo 규칙을 만들어라 vim /etc/sudoers
		-- 잘못된 비밀번호 입력 제한 3회 Defaults	passwd_tries
		-- 잘못된 비밀번호 입력 시 내가 원하는 메세지 출력 Defaults	badpass_message
		-- /var/log/sudo/ 폴더에 sudo 사용 로그가 모두 담겨야 한다 Defaults	log_input/output // Defaults	iolog_dir
		-- TTY모드 활성화 Defaults	requiretty
		-- /usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:/snap/bin Defaults	secure_path=""
	- mornitoring.sh를 생성한다
	apt-get -y install sysstat
	vi /root/monitoring.sh
		-- 10분에 한번 'wall'에 뿌리며 오류표시 ㄴㄴ
		-- 운영체제의 아키텍처와 커널버전 uname -a
		-- 물리 프로세서 개수 grep "physical id" /proc/cpuinfo | sort -u | wc -l
		-- 가상 프로세서 개수 grep "processor" /proc/cpuinfo | sort -u | wc -l
		-- 서버의 현재 사용 가능한 RAM과 그 사용률을 백분률로 표시
		-- 서버의 현재 사용 가능한 저장소와 그 사용률,,
		-- 서버의 현재 프로세서 사용률,,
		-- 마지막 부팅 날짜와 시간
		-- lvm 작동 여부
		-- 활성 연결 수 표시
		-- 서버를 사용중인 사용자 수
		-- IPv4 주소와 서버의 MAC주소 표시
		-- sudo 프로그램으로 실행된 명령의 수
		-- 디펜스 중 스크립트의 작동방식을 설명해야하고  수정하지말고 스크립트를 중단해야한다.

printf "#Architecture: "
uname -a

printf "#CPU physical : "
grep "physical id" /proc/cpuinfo | sort -u | wc -l

printf "#vCPU : "
grep "processor" /proc/cpuinfo | sort -u | wc -l

printf "#Memory Usage: "
free -m | grep "Mem" | awk '{printf "%d/%dMB (%.2f%%)\n", $3, $2, $3/$2 * 100}'

printf "#Disk Usage: "
df -a -BM | grep "/dev/mapper" | awk '{used+=$3}END{print used}' | tr -d '\n'
printf "/"
df -a -BM | grep "/dev/mapper" | awk '{total+=$3+$4}END{printf ("%d", total/1024)}' | tr -d '\n'
printf "Gb ("
df -a -BM | grep "/dev/mapper" | awk '{used+=$3; total+=$3+$4}END{printf ("%d", used/total*100)}' | tr -d '\n'
printf "%%)\n"

printf "#CPU load: "
mpstat | grep "all" | awk '{printf "%.1f%%\n", 100-$13}'

printf "#Last boot: "
who -b | awk '{printf $3" "$4"\n"}'

printf "#LVM use: "
if [ "$(lsblk | grep lvm | wc -l)" -gt 0 ] ; then printf "yes\n" ; else printf "no\n" ; fi

printf "#Connections TCP : "
ss | grep -i tcp | wc -l | tr -d '\n'
printf " ESTABLISHED\n"

printf "#User log: "
who | wc -l

printf "#Network: "
hostname -I | tr -d '\n'
printf "("
ip link show | awk '$1 == "link/ether" {print $2}' | sed '2, $d' | tr -d '\n'
printf ")\n"

printf "#Sudo : "
journalctl _COMM=sudo | wc -l | tr -d '\n'
printf " cmd\n"

exit 0
		chmod +x monitoring.sh
		crontab -e
		*/10 * * * * /root/monitoring.sh | wall

