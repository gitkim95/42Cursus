[mysqld]
# MySQL 데몬 설정 시작

user = mysql
# MySQL 데몬을 실행할 사용자 설정

pid-file = /var/run/mysqld/mysqld.pid
# MySQL 데몬의 PID 파일 경로 설정

socket = /var/run/mysqld/mysqld.sock
# MySQL 소켓 파일 경로 설정

port = 3306
# MySQL 포트 설정

datadir = /var/lib/mysql
# MySQL 데이터 디렉토리 설정

log-error = /var/log/mysql/error.log
# MySQL 에러 로그 파일 경로 설정

# 추가적인 설정 예시
max_connections = 200
# 최대 연결 수 설정

sql_mode = STRICT_TRANS_TABLES
# SQL 모드 설정

skip-grant-tables=0